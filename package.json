{
  "name": "s3-file-id",
  "version": "2.0.2",
  "description": "File ID is a unique identifier for a file. It is used to identify a file in a storage system and to delete it on storage (scheduled).",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "postinstall": "allow-scripts auto",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "test:report": "bun test --reporter=junit --reporter-outfile=junit.xml",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "author": {
    "email": "lynicis@protonmail.com",
    "name": "Emre Sirmali",
    "url": "https://github.com/lynicis"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lynicis/s3-file-id.git"
  },
  "homepage": "https://github.com/lynicis/s3-file-id",
  "bugs": {
    "url": "https://github.com/lynicis/s3-file-id/issues"
  },
  "keywords": [
    "s3",
    "aws-s3",
    "s3-file-id",
    "file-id",
    "fileid",
    "object-storage",
    "s3-object",
    "storage-id",
    "unique-id",
    "identifier",
    "scheduled-delete",
    "lifecycle",
    "file-management",
    "storage-utils",
    "aws",
    "typescript",
    "bun",
    "node",
    "utility"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lavamoat/allow-scripts": "^5.1.0",
    "@lavamoat/preinstall-always-fail": "^3.0.0",
    "@types/bun": "1.3.14",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.1",
    "prettier": "3.9.5",
    "typescript-eslint": "^8.63.0"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22.0.0"
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail#3.0.0": false
    }
  },
  "dependencies": {
    "@types/eslint-plugin-security": "^3.0.1"
  }
